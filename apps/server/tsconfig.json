{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@shared/*": [
                "../../packages/shared/*"
            ]
        }
    },
    "references": [
        {
            "path": "../../packages/shared"
        }
    ],
    "exclude": [
        "node_modules",
        "dist",
        "prisma.config.ts",
        "vitest.config.ts",
        "vitest.e2e.config.ts"
    ]
}