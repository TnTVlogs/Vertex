# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/vertex

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,app://vertex

# ── Uploads ───────────────────────────────────────────────────────────────────
# Public base URL of this server (used to build avatar/attachment URLs)
SERVER_BASE_URL=https://yourdomain.com

# Comma-separated list of additional allowed attachment hostnames (besides own server)
ALLOWED_ATTACHMENT_HOSTS=

# ── WebRTC / TURN ─────────────────────────────────────────────────────────────
# STUN server (optional, defaults to Google STUN)
STUN_URL=stun:stun.l.google.com:19302
# TURN server (required for calls behind strict NAT)
# Leave blank to use STUN-only (calls may fail on some networks)
TURN_URL=turn:turn.yourdomain.com:3478
TURN_USER=vertex
TURN_PASS=your_turn_secret

# ── mediasoup SFU (voice channels) ────────────────────────────────────────────
# Public IP of THIS server — run: curl -s ifconfig.me
MEDIASOUP_ANNOUNCED_IP=1.2.3.4
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999
