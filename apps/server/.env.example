# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/vertex

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,app://vertex

# ── Attachments ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed attachment hostnames
ALLOWED_ATTACHMENT_HOSTS=cdn.yourdomain.com
